{
  \"name\": \"AgnaYI Lead Capture from Webhook\",
  \"nodes\": [
    {
      \"parameters\": {},
      \"id\": \"1\",
      \"name\": \"Webhook\",
      \"type\": \"n8n-nodes-base.webhook\",
      \"typeVersion\": 2,
      \"position\": [240, 300]
    },
    {
      \"parameters\": {
        \"url\": \"=https://your-crm-domain.com/api/webhooks/n8n/\",\r\n
        \"authentication\": \"genericCredentialType\",
        \"genericAuthType\": \"httpHeaderAuth\",
        \"sendHeaders\": true,
        \"headerParameters\": {
          \"parameters\": [
            {
              \"name\": \"X-N8N-Signature\",
              \"value\": \"={{ $env.N8N_WEBHOOK_SECRET }}\"
            }
          ]
        },
        \"sendBody\": true,
        \"bodyParameters\": {
          \"parameters\": [
            {
              \"name\": \"event_type\",
              \"value\": \"new_lead\"
            },
            {
              \"name\": \"payload\",
              \"value\": \"={{ $json }}\"
            }
          ]
        },
        \"options\": {}
      },
      \"id\": \"2\",
      \"name\": \"Send to CRM\",
      \"type\": \"n8n-nodes-base.httpRequest\",
      \"typeVersion\": 4.2,
      \"position\": [460, 300]
    },
    {
      \"parameters\": {
        \"conditions\": {
          \"options\": {
            \"caseSensitive\": true,
            \"leftValue\": \"\",
            \"typeValidation\": \"strict\"
          },
          \"conditions\": [
            {
              \"id\": \"c1\",
              \"leftValue\": \"={{ $json.status }}\",
              \"rightValue\": \"success\",
              \"operator\": {
                \"type\": \"string\",
                \"operation\": \"equals\"
              }
            }
          ],
          \"combinator\": \"and\"
        },
        \"options\": {}
      },
      \"id\": \"3\",
      \"name\": \"Check Success\",
      \"type\": \"n8n-nodes-base.if\",
      \"typeVersion\": 3,
      \"position\": [680, 300]
    },
    {
      \"parameters\": {
        \"jsCode\": \"// Send Twilio SMS welcome\nreturn items;\"
      },
      \"id\": \"4\",
      \"name\": \"Send Welcome SMS (Twilio)\",
      \"type\": \"n8n-nodes-base.code\",
      \"typeVersion\": 2,
      \"position\": [900, 200]
    }
  ],
  \"connections\": {
    \"Webhook\": {
      \"main\": [
        [
          {
            \"node\": \"Send to CRM\",
            \"type\": \"main\",
            \"index\": 0
          }
        ]
      ]
    },
    \"Send to CRM\": {
      \"main\": [
        [
          {
            \"node\": \"Check Success\",
            \"type\": \"main\",
            \"index\": 0
          }
        ]
      ]
    },
    \"Check Success\": {
      \"main\": [
        [
          {
            \"node\": \"Send Welcome SMS (Twilio)\",
            \"type\": \"main\",
            \"index\": 0
          }
        ],
        [
          {
            \"node\": \"Error Log\",
